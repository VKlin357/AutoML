{
  "type": "object",
  "required": ["dataset", "columns", "missing", "basic_stats", "notes"],
  "properties": {
    "dataset": {"type": "string"},
    "columns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "dtype", "n_unique"],
        "properties": {
          "name": {"type": "string"},
          "dtype": {"type": "string"},
          "n_unique": {"type": "integer", "minimum": 0}
        }
      }
    },
    "missing": {
      "type": "object",
      "required": ["total_missing_frac"],
      "properties": {
        "total_missing_frac": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "basic_stats": {
      "type": "object",
      "properties": {
        "n_rows": {"type": "integer", "minimum": 0},
        "n_cols": {"type": "integer", "minimum": 0}
      }
    },
    "notes": {"type": "array", "items": {"type": "string"}}
  }
}
